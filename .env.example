APP_NAME=Enterprise RAG
APP_ENV=development
APP_DEBUG=true
LOG_LEVEL=INFO
SECURITY_ENABLED=true
SECURITY_JWT_SECRET=replace-with-at-least-32-random-characters
SECURITY_JWT_ISSUER=wa7errag
SECURITY_JWT_AUDIENCE=wa7errag-api
SECURITY_ACCESS_TOKEN_TTL_SECONDS=3600
SECURITY_LOGIN_RATE_LIMIT=10
SECURITY_LOGIN_RATE_WINDOW_SECONDS=300
SECURITY_BOOTSTRAP_TOKEN=replace-with-one-time-bootstrap-token
SECURITY_ASSET_SIGNING_SECRET=replace-with-a-different-random-signing-secret
RAG_USE_MOCKS=true
RAG_METADATA_PROVIDER=auto
RAG_EMBEDDING_PROVIDER=auto
RAG_VECTOR_STORE_PROVIDER=auto
RAG_OBJECT_STORE_PROVIDER=auto
RAG_REWRITE_PROVIDER=auto
RAG_HYDE_PROVIDER=auto
RAG_RERANK_PROVIDER=auto
RAG_GENERATION_PROVIDER=auto
RAG_TRACE_PROVIDER=auto
RAG_SECURITY_PROVIDER=auto
RAG_STATE_PROVIDER=auto
RAG_EMBEDDING_MODEL=Qwen3-Embedding-8B
RAG_EMBEDDING_DIMENSION=1024
RAG_GENERATION_MODEL=Qwen2.5-72B
RAG_REWRITE_MODEL=Qwen2.5-7B-Instruct
RAG_RERANK_MODEL=bge-reranker-v2-m3
RAG_SHORT_DOCUMENT_LIMIT=6000
RAG_CHUNK_SIZE=6000
RAG_CHUNK_OVERLAP=500
RAG_VECTOR_TOP_K=20
RAG_RERANK_CANDIDATE_COUNT=20
RAG_FINAL_TOP_K=5
RAG_HYDE_ENABLED=true
RAG_HYDE_MODEL=Qwen2.5-7B-Instruct
RAG_SESSION_TTL_SECONDS=86400
RAG_CHAT_RATE_LIMIT=30
RAG_UPLOAD_RATE_LIMIT=10
RAG_RATE_WINDOW_SECONDS=60
RAG_HNSW_M=16
RAG_HNSW_EF_CONSTRUCTION=256
RAG_HNSW_EF_SEARCH=64
MODEL_GATEWAY_BASE_URL=http://localhost:9000/v1
MODEL_GATEWAY_API_KEY=change-me
RERANK_ENDPOINT=http://localhost:9010/rerank
RERANK_API_KEY=change-me
MILVUS_URI=http://localhost:19530
MILVUS_COLLECTION=enterprise_knowledge_tenant_v1
MILVUS_MINIO_ACCESS_KEY=minioadmin
MILVUS_MINIO_SECRET_KEY=change-me
POSTGRES_DSN=postgresql+asyncpg://rag:rag@localhost:5432/rag
REDIS_URL=redis://localhost:6379/0
MINIO_ENDPOINT=localhost:9001
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=rag-assets
MINIO_SECURE=false
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1

POSTGRES_USER=rag
POSTGRES_PASSWORD=change-me
POSTGRES_DB=rag
MINIO_ROOT_USER=change-me
MINIO_ROOT_PASSWORD=change-me
